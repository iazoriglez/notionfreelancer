---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '@/i18n/utils';

const t = useTranslations('es');
const posts = (await getCollection('blog-es'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog para freelancers"
  description="Guías, recursos y consejos para freelancers que quieren organizarse mejor con Notion."
>
  <div class="page-header">
    <div class="container">
      <h1 class="page-header__title">{t('blog.title')}</h1>
      <p class="page-header__subtitle">{t('blog.subtitle')}</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      {posts.length === 0 ? (
        <p class="empty">Próximamente los primeros artículos. ¡Vuelve pronto!</p>
      ) : (
        <div class="grid grid--3">
          {posts.map(post => <PostCard post={post} lang="es" />)}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .page-header { padding: 3.5rem 0 2.5rem; background: var(--color-surface); border-bottom: 1px solid var(--color-border); }
  .page-header__title { font-size: 2.25rem; font-weight: 800; margin-bottom: 0.5rem; }
  .page-header__subtitle { font-size: 1.0625rem; color: var(--color-muted); }
  .section { padding: 3rem 0 4rem; }
  .grid { display: grid; gap: 1.5rem; }
  .grid--3 { grid-template-columns: repeat(3, 1fr); }
  .empty { color: var(--color-muted); font-size: 1.0625rem; }
  @media (max-width: 900px) { .grid--3 { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .grid--3 { grid-template-columns: 1fr; } }
</style>
