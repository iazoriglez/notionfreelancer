---
import BaseLayout from '@/layouts/BaseLayout.astro';

const templates = [
  {
    title: 'Freelance CRM Pro',
    description: 'Gestiona clientes, proyectos, facturas e interacciones desde un único workspace. Con fórmulas avanzadas que calculan automáticamente saldos pendientes, porcentajes de facturación y días restantes por proyecto.',
    price: '€19',
    url: 'https://6328908678179.gumroad.com/l/freelance-crm-pro',
    tags: ['CRM', 'Clientes', 'Facturas', 'Proyectos'],
    features: [
      '4 bases de datos relacionadas (Clientes, Proyectos, Facturas, Interacciones)',
      'Fórmulas avanzadas: saldo pendiente, % facturado, días restantes',
      'Kanban pipeline de clientes',
      'Dashboard principal con métricas clave',
      'Calendario de entregas y pagos',
    ],
  },
  {
    title: 'Freelance Finance Tracker',
    description: 'Controla ingresos, gastos, IVA e IRPF automáticamente. Diseñado para autónomos españoles que presentan el Modelo 303 (IVA trimestral) y el Modelo 100 (IRPF anual) — se acabaron las hojas de cálculo cada trimestre.',
    price: '€25',
    url: 'https://6328908678179.gumroad.com/l/freelance-finance-tracker-es',
    tags: ['Finanzas', 'IVA', 'IRPF', 'Impuestos'],
    features: [
      '4 bases de datos relacionadas (Ingresos, Gastos, Trimestres, Años Fiscales)',
      'Fórmulas automáticas de IVA e IRPF por factura',
      'Resumen trimestral listo para el Modelo 303',
      'Estimación anual de IRPF con los tramos reales de la Agencia Tributaria',
      'Dashboard central con métricas financieras clave',
    ],
  },
];
---

<BaseLayout
  title="Templates de Notion para Freelancers"
  description="Plantillas de Notion con fórmulas avanzadas y bases de datos relacionadas para organizar tu negocio freelance."
>
  <div class="page-header">
    <div class="container">
      <h1 class="page-header__title">Templates de Notion</h1>
      <p class="page-header__subtitle">
        Sistemas construidos con fórmulas avanzadas y bases de datos relacionadas.
        No son templates básicos — están diseñados por un desarrollador.
      </p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="templates-grid">
        {templates.map(template => (
          <article class="template-card">
            <div class="template-card__header">
              <div>
                <h2 class="template-card__title">{template.title}</h2>
                <div class="template-card__tags">
                  {template.tags.map(tag => <span class="tag">{tag}</span>)}
                </div>
              </div>
              <div class="template-card__price">{template.price}</div>
            </div>
            <p class="template-card__description">{template.description}</p>
            <ul class="template-card__features">
              {template.features.map(f => <li>{f}</li>)}
            </ul>
            <a href={template.url} class="btn btn--primary template-card__cta" target="_blank" rel="noopener">
              Conseguir template →
            </a>
          </article>
        ))}
      </div>

      <div class="coming-soon">
        <h2>Próximamente</h2>
        <p>Más templates en construcción: Client Portal, Time Tracker.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header { padding: 3.5rem 0 2.5rem; background: var(--color-surface); border-bottom: 1px solid var(--color-border); }
  .page-header__title { font-size: 2.25rem; font-weight: 800; margin-bottom: 0.5rem; }
  .page-header__subtitle { font-size: 1.0625rem; color: var(--color-muted); max-width: 600px; }
  .section { padding: 3rem 0 5rem; }
  .templates-grid { display: grid; gap: 2rem; }

  .template-card { border: 1px solid var(--color-border); border-radius: calc(var(--radius) * 2); padding: 2rem; }
  .template-card__header { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; margin-bottom: 1rem; }
  .template-card__title { font-size: 1.5rem; font-weight: 800; margin-bottom: 0.5rem; }
  .template-card__tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .template-card__price { font-size: 2rem; font-weight: 800; color: var(--color-accent); white-space: nowrap; }
  .template-card__description { color: var(--color-muted); line-height: 1.7; margin-bottom: 1.5rem; }
  .template-card__features { list-style: none; margin-bottom: 2rem; display: grid; gap: 0.5rem; }
  .template-card__features li { display: flex; gap: 0.5rem; font-size: 0.9375rem; }
  .template-card__features li::before { content: '✓'; color: var(--color-accent); font-weight: 700; flex-shrink: 0; }

  .coming-soon { margin-top: 4rem; padding: 2rem; background: var(--color-surface); border-radius: calc(var(--radius) * 1.5); border: 1px dashed var(--color-border); }
  .coming-soon h2 { font-size: 1.125rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--color-muted); }
  .coming-soon p { color: var(--color-muted); }
</style>
