---
import { useTranslations, getAlternatePath, type Lang } from '@/i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const alternatePath = getAlternatePath(Astro.url);
const alternateLang = lang === 'es' ? 'en' : 'es';
const alternateLangLabel = lang === 'es' ? 'EN' : 'ES';

const navLinks = [
  { href: `/${lang}/`, label: t('nav.home') },
  { href: `/${lang}/blog/`, label: t('nav.blog') },
  { href: `/${lang}/templates/`, label: t('nav.templates') },
  { href: `/${lang}/${lang === 'es' ? 'sobre-mi' : 'about'}/`, label: t('nav.about') },
];

const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="container header__inner">
    <a href={`/${lang}/`} class="header__logo">
      <span class="header__logo-icon">📋</span>
      <span>Notion<strong>Freelancer</strong></span>
    </a>

    <nav class="header__nav" aria-label="Main navigation">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={['header__nav-link', { 'header__nav-link--active': currentPath === link.href }]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="header__actions">
      <a href={alternatePath} class="header__lang" title={`Switch to ${alternateLang}`} hreflang={alternateLang}>
        {alternateLangLabel}
      </a>
      <a href={`/${lang}/templates/`} class="btn btn--primary header__cta">
        {t('nav.templates')}
      </a>
    </div>

    <button class="header__menu-btn" aria-label="Toggle menu" id="menu-toggle">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-toggle');
  const nav = document.querySelector('.header__nav') as HTMLElement;
  btn?.addEventListener('click', () => {
    nav.classList.toggle('header__nav--open');
  });
</script>

<style>
  .header {
    position: sticky; top: 0; z-index: 100;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
  }
  .header__inner {
    display: flex; align-items: center; gap: 2rem;
    height: 64px;
  }
  .header__logo {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 1.125rem; color: var(--color-text);
    text-decoration: none; white-space: nowrap;
    flex-shrink: 0;
  }
  .header__logo strong { color: var(--color-accent); }
  .header__logo-icon { font-size: 1.25rem; }

  .header__nav {
    display: flex; align-items: center; gap: 0.25rem;
    flex: 1;
  }
  .header__nav-link {
    padding: 0.4rem 0.75rem; border-radius: var(--radius);
    font-size: 0.9375rem; color: var(--color-muted);
    text-decoration: none; transition: all 0.15s;
  }
  .header__nav-link:hover { color: var(--color-text); background: var(--color-surface); text-decoration: none; }
  .header__nav-link--active { color: var(--color-accent); font-weight: 600; }

  .header__actions { display: flex; align-items: center; gap: 0.75rem; margin-left: auto; }
  .header__lang {
    font-size: 0.8125rem; font-weight: 700; letter-spacing: 0.05em;
    color: var(--color-muted); padding: 0.3rem 0.6rem;
    border: 1.5px solid var(--color-border); border-radius: var(--radius);
    text-decoration: none; transition: all 0.15s;
  }
  .header__lang:hover { color: var(--color-accent); border-color: var(--color-accent); text-decoration: none; }

  .header__menu-btn {
    display: none; flex-direction: column; gap: 5px;
    background: none; border: none; cursor: pointer; padding: 4px;
  }
  .header__menu-btn span { display: block; width: 22px; height: 2px; background: var(--color-text); border-radius: 2px; }

  @media (max-width: 768px) {
    .header__nav {
      display: none; position: absolute; top: 64px; left: 0; right: 0;
      flex-direction: column; align-items: flex-start;
      background: white; border-bottom: 1px solid var(--color-border);
      padding: 1rem 1.5rem; gap: 0.25rem;
    }
    .header__nav--open { display: flex; }
    .header__cta { display: none; }
    .header__menu-btn { display: flex; }
  }
</style>
