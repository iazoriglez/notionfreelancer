---
import { useTranslations, type Lang } from '@/i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href={`/${lang}/`} class="footer__logo">
        📋 Notion<strong>Freelancer</strong>
      </a>
      <p class="footer__tagline">{t('footer.tagline')}</p>
    </div>

    <nav class="footer__nav">
      <a href={`/${lang}/blog/`}>{t('nav.blog')}</a>
      <a href={`/${lang}/templates/`}>{t('nav.templates')}</a>
      <a href={`/${lang}/${lang === 'es' ? 'sobre-mi' : 'about'}/`}>{t('nav.about')}</a>
    </nav>

    <div class="footer__langs">
      <a href={`/es/`} hreflang="es" class:list={[{ active: lang === 'es' }]}>Español</a>
      <span>·</span>
      <a href={`/en/`} hreflang="en" class:list={[{ active: lang === 'en' }]}>English</a>
    </div>
  </div>
  <div class="footer__bottom">
    <div class="container">
      <p>&copy; {year} NotionFreelancer. {t('footer.rights')}</p>
    </div>
  </div>
</footer>

<style>
  .footer { background: var(--color-surface); border-top: 1px solid var(--color-border); margin-top: 4rem; }
  .footer__inner {
    display: grid; grid-template-columns: 1fr auto auto;
    align-items: center; gap: 3rem; padding: 2.5rem 0;
  }
  .footer__logo {
    display: block; font-size: 1.0625rem; font-weight: 600;
    color: var(--color-text); text-decoration: none; margin-bottom: 0.5rem;
  }
  .footer__logo strong { color: var(--color-accent); }
  .footer__tagline { font-size: 0.875rem; color: var(--color-muted); }
  .footer__nav { display: flex; flex-direction: column; gap: 0.5rem; }
  .footer__nav a { font-size: 0.875rem; color: var(--color-muted); text-decoration: none; }
  .footer__nav a:hover { color: var(--color-accent); }
  .footer__langs { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; }
  .footer__langs a { color: var(--color-muted); text-decoration: none; }
  .footer__langs a.active { color: var(--color-accent); font-weight: 600; }
  .footer__langs span { color: var(--color-border); }
  .footer__bottom { border-top: 1px solid var(--color-border); padding: 1rem 0; }
  .footer__bottom p { font-size: 0.8125rem; color: var(--color-muted); }

  @media (max-width: 640px) {
    .footer__inner { grid-template-columns: 1fr; gap: 1.5rem; }
    .footer__nav { flex-direction: row; flex-wrap: wrap; }
  }
</style>
