---
import BaseLayout from './BaseLayout.astro';
import { getLangFromUrl } from '@/i18n/utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog-es'> | CollectionEntry<'blog-en'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, tags } = post.data;
const lang = getLangFromUrl(Astro.url);

const formattedPubDate = pubDate.toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const formattedUpdatedDate = updatedDate?.toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout title={title} description={description} image={heroImage} type="article">
  <article class="post">
    {heroImage && (
      <div class="post__hero">
        <img src={heroImage} alt={title} width="1200" height="630" loading="eager" />
      </div>
    )}
    <div class="container--narrow">
      <header class="post__header">
        {tags.length > 0 && (
          <div class="post__tags">
            {tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        )}
        <h1 class="post__title">{title}</h1>
        <p class="post__description">{description}</p>
        <div class="post__meta">
          <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
          {updatedDate && (
            <span class="post__updated">
              · {lang === 'es' ? 'Actualizado' : 'Updated'}: <time datetime={updatedDate.toISOString()}>{formattedUpdatedDate}</time>
            </span>
          )}
        </div>
      </header>
      <div class="prose">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post { padding-bottom: 4rem; }
  .post__hero { max-height: 480px; overflow: hidden; }
  .post__hero img { width: 100%; object-fit: cover; display: block; }
  .post__header { padding: 2.5rem 0 2rem; border-bottom: 1px solid var(--color-border); margin-bottom: 2rem; }
  .post__tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .post__title { font-size: 2.25rem; font-weight: 800; line-height: 1.2; margin-bottom: 0.75rem; }
  .post__description { font-size: 1.125rem; color: var(--color-muted); margin-bottom: 1rem; line-height: 1.6; }
  .post__meta { font-size: 0.875rem; color: var(--color-muted); }
  .post__updated { font-style: italic; }

  @media (max-width: 640px) {
    .post__title { font-size: 1.75rem; }
  }
</style>
